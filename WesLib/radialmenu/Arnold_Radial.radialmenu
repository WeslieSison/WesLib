			"script":"pane = kwargs['pane']\nnetwork = pane.pwd()\nnet_editor = hou.ui.paneTabUnderCursor()\ncursor_pos = net_editor.cursorPosition()\n\n\nnode = network.createNode(\"arnold::color_correct\")\nnode.setPosition(cursor_pos)\n"
