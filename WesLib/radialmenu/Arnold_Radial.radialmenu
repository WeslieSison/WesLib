	"label":"Arnold_Radial",
	"type":"submenu",
	"items":{
		"0":{
			"label":"ar Image",
			"type":"script_action",
			"icon":"hicon:/SVGIcons.index?SOP_uvquickshade.svg",
			"script":"pane = kwargs['pane']\nnetwork = pane.pwd()\nnet_editor = hou.ui.paneTabUnderCursor()\ncursor_pos = net_editor.cursorPosition()\n\n\nnode = network.createNode(\"arnold::image\")\nnode.setPosition(cursor_pos)\n"
		},
		"2":{
			"label":"ar Ramp",
			"type":"submenu",
			"items":{
				"0":{
					"label":"ramp RGB",
					"type":"script_action",
					"icon":"hicon:/SVGIcons.index?VOP_blendregions.svg",
					"script":"pane = kwargs['pane']\nnetwork = pane.pwd()\nnet_editor = hou.ui.paneTabUnderCursor()\ncursor_pos = net_editor.cursorPosition()\n\n\nnode = network.createNode(\"arnold::ramp_rgb::2\")\nnode.setPosition(cursor_pos)\n"
				},
				"4":{
					"label":"ramp Float",
					"type":"script_action",
					"icon":"hicon:/SVGIcons.index?IMAGE_gamma.svg",
					"script":"pane = kwargs['pane']\nnetwork = pane.pwd()\nnet_editor = hou.ui.paneTabUnderCursor()\ncursor_pos = net_editor.cursorPosition()\n\n\nnode = network.createNode(\"arnold::ramp_float::2\")\nnode.setPosition(cursor_pos)\n"
				}
